# Same as project root .env.example — place as server/.env for local dev.
# See ../.env.example

NODE_ENV=development
PORT=5000

MONGODB_URI=
MONGODB_DB_NAME=codearena_x
MONGODB_USE_PUBLIC_DNS=true
JWT_SECRET=
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:5173
# Optional: comma-separated extra origins (custom domains, etc.).
# CORS_ORIGINS=https://www.example.com
# CORS_ALLOW_VERCEL_HOSTING=true

GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

JUDGE0_API_URL=
JUDGE0_API_KEY=

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
