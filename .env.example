# CodeArena X — copy to server/.env (or merge with your local env)
# The API loads server/.env first (see server/src/config/env.js). Never commit real values.

NODE_ENV=development
PORT=5000

# Required
MONGODB_URI=
MONGODB_DB_NAME=codearena_x
MONGODB_USE_PUBLIC_DNS=true
# Optional: standard mongodb:// seed list if SRV/DNS issues
# MONGODB_DIRECT_URI=
JWT_SECRET=
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:5173
# Optional: comma-separated extra origins (exact match, e.g. production Vercel while API runs locally).
# CORS_ORIGINS=https://your-app.vercel.app

# GROQ (AI: hints, mentor, mock interview)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Judge0 (code run / submit)
JUDGE0_API_URL=
JUDGE0_API_KEY=
# JUDGE0_RAPIDAPI_HOST=
# JUDGE0_MAX_WAIT_MS=120000
# JUDGE0_POLL_MS=350

# Google OAuth (optional)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_CALLBACK_URL=

# Razorpay (Pro checkout — use test keys in development)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# RAZORPAY_PRO_AMOUNT_PAISE=19900
# RAZORPAY_CURRENCY=INR
# PAYMENT_ALLOW_SIMULATED_UPGRADE=false
